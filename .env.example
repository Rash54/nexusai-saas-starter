# NexusAI SaaS Starter — Environment Variables
# Copy this file to .env and fill in your values.

# ── App ───────────────────────────────────────────────────
APP_NAME="NexusAI SaaS Starter"
ENVIRONMENT=development
DEBUG=false

NEXT_PUBLIC_API_URL=http://localhost:8001
# ── Security ──────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Frontend ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Email (Resend) — optional ─────────────────────────────
# Get a free API key at https://resend.com
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ─────────────────────────────────────────────────────────
# The following are PRO EDITION features.
# Upgrade at https://nexusai.gumroad.com
# ─────────────────────────────────────────────────────────

# ── AI Providers (Pro) ────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Stripe (Pro) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Redis / Celery (Pro) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Banking — Plaid (Pro) ─────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
